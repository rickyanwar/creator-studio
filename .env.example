# ─────────────────────────────────────────────
#  ig-fb-reposter · environment config
#  Copy to .env and fill in real values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://reposter:changeme@db:5432/reposter

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ──────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-jwt-secret-key-here

# ── Admin Auth ────────────────────────────────
ADMIN_USERNAME=admin
# Generate: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('yourpassword'))"
ADMIN_PASSWORD_HASH=run-create_admin-script-to-set-this

# ── Storage ───────────────────────────────────
# Path on VPS where images are stored
STORAGE_BASE_PATH=/var/www/media
# Public HTTPS URL served by Nginx
STORAGE_BASE_URL=https://cdn.yourdomain.com/media

# ── AI Providers ──────────────────────────────
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Groq Console: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key

# ── Repliz API ────────────────────────────────
REPLIZ_ACCESS_KEY=your-repliz-access-key
REPLIZ_SECRET_KEY=your-repliz-secret-key

# ── Repliz Configuration ──────────────────────
REPLIZ_BASE_URL=https://api.repliz.com

# ── Crawl Settings ────────────────────────────
CRAWL_INTERVAL_MINUTES=30
# Sleep window: do not crawl between these WIB hours (UTC+7)
CRAWL_SLEEP_START_WIB=1
CRAWL_SLEEP_END_WIB=6

# ── AI Failover ───────────────────────────────
AI_FALLBACK_AFTER_FAILURES=3
AI_FALLBACK_RESET_AFTER_MINUTES=15

# ── Notifications (optional Phase 7) ──────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Environment ───────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
